        {
          "name": "Get orders by date range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ordermsBaseUrl}}/orders/search/date-range?startDate=2026-01-01T00:00:00&endDate=2026-12-31T23:59:59",
              "host": ["{{ordermsBaseUrl}}"],
              "path": ["orders", "search", "date-range"],

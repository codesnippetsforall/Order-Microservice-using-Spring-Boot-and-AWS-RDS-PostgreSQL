# Cognito settings — production values are in AWS Secrets Manager: winsoon/orderms/cognito
# For local dev without AWS, copy to deploy/cognito-dev.env and fill in values (never commit cognito-dev.env).
COGNITO_REGION=XXXX
COGNITO_USER_POOL_ID=XXXX_XXXXXXXXX
COGNITO_ISSUER_URI=https://cognito-idp.XXXX.amazonaws.com/XXXX_XXXXXXXXX
COGNITO_DOMAIN=XXXX.auth.XXXX.amazoncognito.com
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# Test user password: store in a password manager, not in git
